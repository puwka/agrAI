generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String   @id @default(cuid())
  name                 String
  email                String   @unique
  passwordHash         String
  role                 String   @default("USER") // ADMIN | USER
  restrictedUntil      DateTime?
  restrictedReason     String?
  company              String?
  telegram             String?
  notificationsEnabled Boolean  @default(true)
  weeklyReportEnabled  Boolean  @default(false)
  defaultAspectRatio   String   @default("16:9")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  generations          Generation[]
  apiKeys              ApiKey[]
}

/// Глобальные настройки приложения (одна строка id = global)
model AppSettings {
  id                   String   @id @default("global")
  maintenanceEnabled   Boolean  @default(false)
  maintenanceMessage   String   @default("Ведутся технические работы. Генерация временно недоступна.")
  updatedAt            DateTime @updatedAt
}

model Generation {
  id           String   @id @default(cuid())
  userId       String
  modelId      String
  modelName    String
  /// TEXT — из текста; IMAGE_REF — из загруженного фото (фото/видео)
  inputMode          String   @default("TEXT")
  /// Исходное фото пользователя (путь в public), только для IMAGE_REF
  referenceImageUrl  String?
  prompt       String
  aspectRatio  String
  status         String   @default("PENDING") // PENDING | QUEUED | SUCCESS | ERROR
  resultUrl      String?
  /// Текст от администратора (ошибка, авторские права и т.д.); может быть без файла
  resultMessage  String?
  errorMessage   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ApiKey {
  id           String    @id @default(cuid())
  userId       String
  name         String
  token        String
  status       String    @default("ACTIVE") // ACTIVE | LIMITED
  scope        String
  monthlyQuota Int       @default(25000)
  usageCount   Int       @default(0)
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

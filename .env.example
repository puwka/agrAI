# ─── Supabase (URL + Keys) ────────────────────────────────────────────────────
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_ANON_KEY="<anon-key>"
# Только для серверных задач/cron/admin API. Никогда не отдавать на клиент.
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# ─── Prisma / PostgreSQL ──────────────────────────────────────────────────────
# Pooler URL (рекомендуется для runtime в Vercel)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# ─── NextAuth ────────────────────────────────────────────────────────────────
# Локально
NEXTAUTH_URL="http://localhost:3000"
# Продакшен / preview: https://<проект>.vercel.app или свой домен (без слэша в конце)
# NEXTAUTH_URL="https://your-app.vercel.app"
# Preview/prod fallback: NEXTAUTH_URL подставляется из VERCEL_URL в instrumentation.ts (next-auth v4).

NEXTAUTH_SECRET="replace-with-long-random-string-min-32-chars"

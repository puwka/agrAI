# ─── SQLite (оставляем provider = sqlite в prisma/schema.prisma) ─────────────
#
# Локально: файл в каталоге проекта
DATABASE_URL="file:./prisma/dev.db"
#
# Vercel (Serverless): запись только в /tmp — см. instrumentation.ts (миграции при старте).
# БД эфемерна между деплоями и холодными стартами; для постоянного SQLite в облаке обычно
# используют Turso (libSQL), это всё ещё экосистема SQLite.
# DATABASE_URL="file:/tmp/agrai.db"
#
# На этапе build на Vercel задайте ту же DATABASE_URL, что и в runtime (часто тот же /tmp
# или отдельный file:./.build/db.sqlite только для migrate deploy — см. переменные в Vercel).

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Локально
NEXTAUTH_URL="http://localhost:3000"
# Продакшен / preview: https://<проект>.vercel.app или свой домен (без слэша в конце)
# NEXTAUTH_URL="https://your-app.vercel.app"

NEXTAUTH_SECRET="replace-with-long-random-string-min-32-chars"
